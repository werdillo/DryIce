---
import "../styles/global.css";
import Main from "@/layouts/main.astro";
import { BlockFactory } from "@/components/BlockFactory";
import pageData from "@/data/index.json";

const lang = "en";
const content = pageData.meta[lang];
const blocks = [...pageData.blocks].sort((a, b) => a.order - b.order);
---

<Main content={content} lang={lang}>
    {
        blocks.map((block) => (
            <BlockFactory client:load block={block} lang={lang} />
        ))
    }
</Main>
