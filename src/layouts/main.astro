---
import "../styles/global.css";
import { Footer } from "./footer";
import { Sidebar } from "./sidebar";
import { Header } from "./header";
import pageData from "@/data/index.json";

const { content, lang = "en" } = Astro.props;
type Lang = "en" | "lv";
const currentLang = (["en", "lv"].includes(lang) ? lang : "en") as Lang;

const headerData = pageData.layout.header[currentLang];
const footerData = pageData.layout.footer[currentLang];
const sidebarData = pageData.layout.sidebar[currentLang];
---

<html lang={currentLang}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <title>{content.title}</title>
        <meta name="description" content={content.description} />
        <meta name="keywords" content={content.keywords} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&display=swap"
            rel="stylesheet"
        />
    </head>
    <body class="dark">
        <Header
            client:load
            lang={currentLang}
            buttonText={headerData.buttonText}
            buttonHref={headerData.buttonHref}
        />
        <div class="flex flex-col gap-30">
            <slot />
        </div>
        <Footer config={footerData} />
        <Sidebar client:load config={sidebarData} />
    </body>
</html>
