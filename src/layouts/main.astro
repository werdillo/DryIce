---
import { LpNavbar4 } from "@/components/pro-blocks/landing-page/lp-navbars/lp-navbar-4";
import "../styles/global.css";
const { content } = Astro.props;
import { Footer } from "./footer";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <title>{content.title}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&display=swap"
            rel="stylesheet"
        />
    </head>
    <body class="dark">
        <div class="flex flex-col gap-30">
            <slot />
        </div>
        <Footer />
    </body>
</html>
